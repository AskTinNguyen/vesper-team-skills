{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memory.system/atomic-fact-schema.json",
  "title": "Atomic Fact Schema",
  "description": "Schema for entity facts in the three-layer memory system",
  "type": "object",
  "required": ["entity", "type", "created", "facts"],
  "properties": {
    "entity": {
      "type": "string",
      "description": "Entity identifier (folder name)"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable entity name"
    },
    "type": {
      "type": "string",
      "enum": ["person", "company", "project"],
      "description": "Entity type"
    },
    "created": {
      "type": "string",
      "format": "date",
      "description": "Entity creation date (YYYY-MM-DD)"
    },
    "facts": {
      "type": "array",
      "description": "List of atomic facts about this entity",
      "items": {
        "type": "object",
        "required": ["id", "fact", "timestamp", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique fact identifier (entity-NNN format)",
            "pattern": "^[a-z0-9-]+-[0-9]{3}$"
          },
          "fact": {
            "type": "string",
            "description": "The actual fact text",
            "minLength": 1,
            "maxLength": 500
          },
          "category": {
            "type": "string",
            "enum": ["relationship", "milestone", "status", "preference"],
            "description": "Category of the fact"
          },
          "timestamp": {
            "type": "string",
            "format": "date",
            "description": "When this fact was recorded (YYYY-MM-DD)"
          },
          "source": {
            "type": "string",
            "enum": ["conversation", "manual", "heartbeat", "synthesis", "example"],
            "description": "How this fact was captured"
          },
          "status": {
            "type": "string",
            "enum": ["active", "superseded"],
            "description": "Whether this fact is current or historical"
          },
          "supersededBy": {
            "type": "string",
            "description": "ID of the fact that replaced this one (when status=superseded)",
            "pattern": "^[a-z0-9-]+-[0-9]{3}$"
          },
          "supersededDate": {
            "type": "string",
            "format": "date",
            "description": "When this fact was superseded (YYYY-MM-DD)"
          },
          "notes": {
            "type": "string",
            "description": "Optional additional context"
          }
        }
      }
    }
  },
  "examples": [
    {
      "entity": "maria",
      "display_name": "Maria Rodriguez",
      "type": "person",
      "created": "2026-01-15",
      "facts": [
        {
          "id": "maria-001",
          "fact": "Business partner on AI project",
          "category": "relationship",
          "timestamp": "2026-01-15",
          "source": "conversation",
          "status": "active"
        },
        {
          "id": "maria-002",
          "fact": "Company hired two developers",
          "category": "milestone",
          "timestamp": "2026-01-20",
          "source": "heartbeat",
          "status": "active"
        },
        {
          "id": "maria-003",
          "fact": "Former colleague at OldCo",
          "category": "relationship",
          "timestamp": "2025-06-01",
          "source": "manual",
          "status": "superseded",
          "supersededBy": "maria-001",
          "supersededDate": "2026-01-15"
        }
      ]
    }
  ]
}
