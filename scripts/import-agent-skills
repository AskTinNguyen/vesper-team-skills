#!/usr/bin/env bash
# import-agent-skills - Import upstream agent-skills into vesper-team-skills
#
# Copies all skill directories from an upstream addyosmani/agent-skills clone into
# this repository root, refreshes upstream provenance files, and optionally
# symlinks the imported skills into common local skill roots.
#
# Default source: ~/agent-skills/skills
# Default targets:
#   ~/.vesper/skills
#   ~/.claude/skills
#   ~/.codex/skills

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SOURCE_ROOT="${HOME}/agent-skills/skills"
TARGETS="${HOME}/.vesper/skills:${HOME}/.claude/skills:${HOME}/.codex/skills"
BACKUP_ROOT="${HOME}/.skill-import-backups/agent-skills-$(date +%Y%m%d-%H%M%S)"
LINK_TARGETS=true

show_help() {
  cat <<EOF
Usage: import-agent-skills [OPTIONS]

Import upstream addyosmani/agent-skills into this repo and optionally symlink the
imported skills into local skill roots.

OPTIONS:
  --source DIR        Path to upstream skills directory (default: ~/agent-skills/skills)
  --targets LIST      Colon-separated target skill roots for symlinks
                      (default: ~/.vesper/skills:~/.claude/skills:~/.codex/skills)
  --backup-root DIR   Where replaced local skill entries are backed up
  --no-link           Import into repo only; do not create/update symlinks
  -h, --help          Show this help text

EXAMPLES:
  import-agent-skills
  import-agent-skills --source ~/src/agent-skills/skills
  import-agent-skills --no-link
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: required command not found: $1" >&2
    exit 1
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --source)
        SOURCE_ROOT="$2"
        shift 2
        ;;
      --targets)
        TARGETS="$2"
        shift 2
        ;;
      --backup-root)
        BACKUP_ROOT="$2"
        shift 2
        ;;
      --no-link)
        LINK_TARGETS=false
        shift
        ;;
      -h|--help)
        show_help
        exit 0
        ;;
      *)
        echo "Error: unknown option: $1" >&2
        show_help
        exit 1
        ;;
    esac
  done
}

write_provenance() {
  local clone_root="$1"
  local third_party_dir="${REPO_ROOT}/third_party/agent-skills"
  local imported_at
  imported_at="$(date '+%Y-%m-%d %H:%M %Z')"
  local commit='unknown'

  mkdir -p "$third_party_dir"

  if [[ -d "${clone_root}/.git" ]]; then
    commit="$(git -C "$clone_root" rev-parse --short HEAD 2>/dev/null || echo unknown)"
  fi

  if [[ -f "${clone_root}/LICENSE" ]]; then
    cp "${clone_root}/LICENSE" "${third_party_dir}/LICENSE"
  fi

  cat > "${third_party_dir}/README.md" <<EOF
# agent-skills upstream import

Source repository: \
\`https://github.com/addyosmani/agent-skills\`
Imported from local clone: \
\`${clone_root}\`
Imported commit: \
\`${commit}\`
Imported on: \
\`${imported_at}\`

This directory keeps upstream provenance and the MIT license for the imported
skill directories copied into the root of \`vesper-team-skills\`.
EOF
}

link_skill() {
  local base="$1"
  local slug="$2"
  local src="${REPO_ROOT}/${slug}"
  local dest="${base}/${slug}"

  mkdir -p "$base"

  if [[ -L "$dest" ]]; then
    local current
    current="$(readlink "$dest" || true)"
    if [[ "$current" == "$src" ]]; then
      return 0
    fi
    mkdir -p "${BACKUP_ROOT}${base}"
    mv "$dest" "${BACKUP_ROOT}${base}/${slug}"
  elif [[ -e "$dest" ]]; then
    mkdir -p "${BACKUP_ROOT}${base}"
    mv "$dest" "${BACKUP_ROOT}${base}/${slug}"
  fi

  ln -s "$src" "$dest"
}

main() {
  parse_args "$@"
  require_cmd find
  require_cmd sort
  require_cmd rsync

  if [[ ! -d "$SOURCE_ROOT" ]]; then
    echo "Error: source skills directory not found: $SOURCE_ROOT" >&2
    exit 1
  fi

  local clone_root
  clone_root="$(cd "${SOURCE_ROOT}/.." && pwd)"
  local skill_list
  skill_list="$(mktemp)"
  trap "rm -f '$skill_list'" EXIT

  find "$SOURCE_ROOT" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort > "$skill_list"

  while IFS= read -r slug; do
    [[ -z "$slug" ]] && continue
    rm -rf "${REPO_ROOT}/${slug}"
    mkdir -p "${REPO_ROOT}/${slug}"
    rsync -a "${SOURCE_ROOT}/${slug}/" "${REPO_ROOT}/${slug}/"
  done < "$skill_list"

  write_provenance "$clone_root"

  if [[ "$LINK_TARGETS" == true ]]; then
    OLD_IFS="$IFS"
    IFS=':'
    for base in $TARGETS; do
      [[ -z "$base" ]] && continue
      while IFS= read -r slug; do
        [[ -z "$slug" ]] && continue
        link_skill "$base" "$slug"
      done < "$skill_list"
    done
    IFS="$OLD_IFS"
  fi

  local count
  count="$(wc -l < "$skill_list" | tr -d ' ')"
  echo "Imported ${count} skills from ${SOURCE_ROOT} into ${REPO_ROOT}" >&2
  if [[ "$LINK_TARGETS" == true ]]; then
    echo "Symlink targets refreshed: ${TARGETS}" >&2
    echo "Backup root: ${BACKUP_ROOT}" >&2
  else
    echo "Symlink refresh skipped (--no-link)" >&2
  fi
}

main "$@"
