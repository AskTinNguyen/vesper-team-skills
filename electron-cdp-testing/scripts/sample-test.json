{
  "name": "Sample Vesper CDP Smoke",
  "description": "Grounded smoke test for the live Vesper Electron renderer",
  "steps": [
    {
      "action": "assert",
      "expression": "typeof window.electronAPI === 'object'",
      "expected": true,
      "description": "Confirm the preload bridge is available"
    },
    {
      "action": "eval",
      "expression": "document.title",
      "description": "Read the current window title"
    },
    {
      "action": "eval",
      "expression": "(() => { window.location.hash = '#/settings'; return window.location.hash; })()",
      "description": "Navigate to the settings hash"
    },
    {
      "action": "wait",
      "ms": 600,
      "description": "Wait for the route transition"
    },
    {
      "action": "click",
      "text": "Settings",
      "description": "Click a visible Settings control if present",
      "required": false
    },
    {
      "action": "screenshot",
      "output": "vesper-cdp-smoke-settings.png",
      "description": "Capture evidence after navigation"
    }
  ]
}
